    <mj-section background-color="#FFFFFF" padding="20px 15px">
        <mj-column>

            <mj-section background-color="#f48c35" padding="15px 0 15px 0" border-radius="4px">
                        <mj-column>
                            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="20px" color="#ffffff" font-weight="bold" align="center" padding="0">
                                 HỌC SINH TRẦN MINH TRÍ - VISA DU HỌC
                            </mj-text>
                        </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="17.5px" font-style="italic" color="#2e2b2c" align="center" padding="15px 0 2px 0" line-height="1.5">
                Mình rất hài lòng với
                <span style="color: #f48c35; font-weight: bold;">dịch vụ của 360 Connect.</span> Các anh chị rất
                <span style="color: #f48c35; font-weight: bold;">tận tình </span>hỗ trợ trong mọi công đoạn xin hồ sơ visa và chuẩn bị nhập cảnh.
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="20px" color="#2e2b2c" align="center" padding="0 0 10px 0" font-style="italic">
                - <span style="color: #f48c35; font-weight: bold;">Minh Trí </span> chia sẻ -
            </mj-text>

            <mj-section background-color="#fff" padding="15px 0 15px 0">
                <mj-column width="46.5%" text-align="center">
                    <mj-image
                    src="https://dangduy03.github.io/image-limited/So_CT7/z6850013166243_63d218a733454b05f128786b6be6c501.jpg"
                    alt="anh_hieu.png"
                    padding="0"
                    border-radius="5px"
                    
                    />
                </mj-column >

                <mj-column width="53.5%" text-align="center">
                    <mj-image
                    src="https://dangduy03.github.io/image-limited/So_CT7/z6850013115680_14fd82dd0d4e9c3c1ce71d066cf874f7.jpg"
                    alt="visa_nguyen_dinh_hien.png"
                    padding="0"
                    border-radius="5px"
                    
                    />
                </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15.5px"  color="#2e2b2c" align="center" padding="0 0 15px 0" line-height="1.5">
                Từ học sinh trường
                <span style="color: #f48c35; font-weight: bold;">St. Paul American School</span> đến tân sinh viên
                <span style="color: #f48c35; font-weight: bold;">Trinity College - University of Melbourne </span>– hành trình của
                <span style="color: #f48c35; font-weight: bold;">Minh Trí </span>à kết quả của sự chuẩn bị chỉnh chu, định hướng rõ ràng và sự đồng hành đúng cách từ
                <span style="color: #f48c35; font-weight: bold;">360 Connect. </span>
            </mj-text>

        </mj-column>
    </mj-section>











    <mj-section background-color="#5D8346" padding="20px 0 20px 0">
        <mj-column>
            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="25px" color="#ffffff" font-weight="bold" align="center" padding="5px 0">
                ĐIỂM TIN THÁNG
            </mj-text>
        </mj-column>
    </mj-section>


    <mj-section background-color="#fff" padding="15px 0 0 0">
        <mj-column width="50%" >
            <mj-image
            src="https://dangduy03.github.io/image-limited/So_CT7/lephi.png"
            alt="CƠ HỘI DU HỌC, DU LỊCH VÀ ĐỊNH CƯ"
            padding="0"

            />
        </mj-column>

        <mj-column padding="15px" >
            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="16px"  color="#2e2b2c" align="justify"   padding="0 0 15px 0" line-height="1.5">
                Từ ngày
                <span style="color: #f48c35; font-weight: bold;">01/07/2025</span>, Chính phủ Úc chính thức 
                <span style="color: #f48c35; font-weight: bold;">áp dụng nhiều thay đổi lớn</span> liên quan đến 
                <span style="color: #f48c35; font-weight: bold;">lệ phí visa</span>, 
                <span style="color: #f48c35; font-weight: bold;">mức lương</span>tối thiểu, 
                <span style="color: #f48c35; font-weight: bold;">bảo hiểm</span> hưu trí, 
                <span style="color: #f48c35; font-weight: bold;">phúc lợi</span> xã hội và các 
                <span style="color: #f48c35; font-weight: bold;">chính sách </span> hỗ trợ giáo dục.                 
            </mj-text>
            <mj-image href="https://360connect.edu.vn/visa-integrity-fee-ap-dung-tu-10-2025/" 
                 src="https://dangduy03.github.io/image-limited/So_CT6/5.gif" 
                 alt="XEM CHI TIẾT" 
                 padding="15px 0 15px 0"
                 width="200px" />
        </mj-column>
    </mj-section>



    <mj-section background-color="#fff" padding="0px 0 0px 0">
        <mj-column padding="30px 15px">
        <mj-text font-family="Montserrat, Arial, sans-serif" font-size="16px"  color="#2e2b2c" align="justify"   padding="0 0 15px 0" line-height="1.5">
            Theo đó, từ ngày 
            <span style="color: #f48c35; font-weight: bold;">1/9/2025</span>, mức sinh hoạt phí 
            <span style="color: #f48c35; font-weight: bold;">tối thiểu </span>mà sinh viên quốc tế cần chứng minh sẽ được điều chỉnh tăng lên 
            <span style="color: #f48c35; font-weight: bold;"> 22,895 CAD/năm</span>, chưa bao gồm học phí và chi phí đi lại.
        </mj-text>
        <mj-image href="https://360connect.edu.vn/canada-cap-nhat-chung-minh-tai-chinh-moi/" 
                 src="https://dangduy03.github.io/image-limited/So_CT6/6.gif" 
                 alt="TÌM HIỂU THÊM" 
                 padding="15px 0 15px 0"
                 width="200px" />
