            alt="Lịch nghỉ Tết"
            padding="0"
            />
        </mj-column>
    </mj-section>







    <mj-section background-color="#fff" padding="0px 0 0 0">
        <mj-column width="50%" >
            <mj-image
            src="https://dangduy03.github.io/image-limited/So_CT7/phivisa.png"
            alt="CƠ HỘI DU HỌC, DU LỊCH VÀ ĐỊNH CƯ"
            padding="0"
            />
        </mj-column>

        <mj-column padding="30px 15px">
            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="16px"  color="#2e2b2c" align="justify"   padding="0 0 15px 0" line-height="1.5">
                Từ ngày 01
                <span style="color: #f48c35; font-weight: bold;">01/10/2025</span> , Chính phủ Mỹ sẽ 
                <span style="color: #f48c35; font-weight: bold;">áp dụng </span>thêm 
                <span style="color: #f48c35; font-weight: bold;">phí Visa Integrity Fee </span>trị giá 
                <span style="color: #f48c35; font-weight: bold;">250 USD</span> cho tất cả đơn xin visa không định cư, bao gồm 
                <span style="color: #f48c35; font-weight: bold;"> visa du học</span>, 
                <span style="color: #f48c35; font-weight: bold;"> du lịch</span>, 
                <span style="color: #f48c35; font-weight: bold;"> lao động</span> và 
                <span style="color: #f48c35; font-weight: bold;"> trao đổi văn hóa</span>.
            </mj-text>
            <mj-image href="https://360connect.edu.vn/harvard-thoat-luat-cam-tuyen-sinh-quoc-te/" 
