    <mj-section background-color="#FFFFFF" padding="20px 15px">
        <mj-column>

            <mj-section background-color= "#AB0618" padding="15px 0 15px 0" border-radius="4px">
                <mj-column>
                    <mj-text font-family="Montserrat, Arial, sans-serif" font-size="17px" color="#ffffff" font-weight="bold" align="center" padding="0">
                         CHỊ ĐI TRƯỚC - EM NỐI TIẾP HÀNH TRÌNH TẠI ÚC
                    </mj-text>
                </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="15px 0 2px 0" line-height="1.5">
                "Du học không chỉ là 
                <span style="color: #AB0618; font-weight: bold;">bước ngoặt lớn</span>, mà còn là một
                <span style="color: #AB0618; font-weight: bold;">hành trình khám </span>
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 2px 0" line-height="1.5">
                <span style="color: #AB0618; font-weight: bold;"> phá bản thân</span>. Em rất biết ơn sự 
                <span style="color: #AB0618; font-weight: bold;">hỗ trợ tận tâm  </span>từ 360 Connect, 
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 2px 0" line-height="1.5">
                giúp mọi thứ 
                <span style="color: #AB0618; font-weight: bold;">diễn ra thuận lợi</span>. Hiện tại em rất háo hức
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 15px 0" line-height="1.5">
                 trải nghiệm cuộc sống mới tại Úc!" 
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" color="#2e2b2c" align="center" padding="0 0 10px 0" font-style="italic">
                - <span style="color: #AB0618; font-weight: bold;">Minh Khánh</span> chia sẻ -
            </mj-text>

            <mj-section background-color="#fff" padding="25px 0 0 0">
                <mj-column width="50%" >
                    <mj-image
                    href="https://360connect.edu.vn/nguyen-minh-khanh-nhan-visa-du-hoc-uc-trong-hon-3-tuan/" 
                    src="https://dangduy03.github.io/image-limited/So_2025/khanh2.png"
                    alt="CƠ HỘI DU HỌC, DU LỊCH VÀ ĐỊNH CƯ"
                    padding="0"

                    />
                </mj-column>

                <mj-column padding="40px 10px" >
                    <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px"  color="#2e2b2c" align="justify"   padding="0 0 15px 0" line-height="1.5">
                        Chỉ trong hơn có
                        <span style="color: #AB0618; font-weight: bold;">3 tuần </span>bạn
                        <span style="color: #AB0618; font-weight: bold;">Nguyễn Minh Khánh</span> đã thành công nhận được visa du học của
                        <span style="color: #AB0618; font-weight: bold;">xứ sở chuột túi. </span>
                    </mj-text>
                    <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" color="#2e2b2c" align="justify"  padding="0px 0 5px 0" line-height="1.5">
                    👇 Thời gian nhận visa 
                    <span style="color: #AB0618; font-weight: bold;">“tốc độ”</span>
                    </mj-text>
                    <mj-image 
                        href="https://360connect.edu.vn/nguyen-minh-khanh-nhan-visa-du-hoc-uc-trong-hon-3-tuan/" 
                        src="https://dangduy03.github.io/image-limited/So_CT6/5.gif" 
                        alt="XEM CHI TIẾT" 
                        padding="0px 0 0px 0"
                        width="200px" />
                </mj-column>
            </mj-section>
        </mj-column>
    </mj-section>

    </mj-section>

    <mj-section background-color="#FFFFFF" padding="20px 15px">
        <mj-column>

            <mj-section background-color="#AB0618" padding="15px 0 15px 0" border-radius="4px">
                        <mj-column>
                            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="17px" color="#ffffff" font-weight="bold" align="center" padding="0">
                                DU HỌC ÚC: TÀI CHÍNH YẾU CÓ THẬT SỰ LÀ RÀO CẢN?
                            </mj-text>
                        </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="15px 0 2px 0" line-height="1.5">
                “Từ buổi tư vấn đầu tiên đến ngày nhận visa – mọi thứ diễn ra
                <span style="color: #AB0618; font-weight: bold;">nhanh</span>
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 2px 0" line-height="1.5">
                <span style="color: #AB0618; font-weight: bold;">hơn cả kỳ vọng</span>. Khoảnh khắc nhận được visa em cảm thấy mọi
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 2px 0" line-height="1.5">
                công sức chuẩn bị đã được đền đáp và giờ em đã
                <span style="color: #AB0618; font-weight: bold;">sẵn sàng</span>
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="center" padding="0 0 15px 0" line-height="1.5">
                 <span style="color: #AB0618; font-weight: bold;">bắt đầu một hành trình mới</span> !”
            </mj-text>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" color="#2e2b2c" align="center" padding="0 0 10px 0" font-style="italic">
                - <span style="color: #AB0618; font-weight: bold;">Trung Tín</span> chia sẻ -
            </mj-text>


            <mj-section background-color="#fff" padding="25px 0 0 0">
                <mj-column width="50%" >
