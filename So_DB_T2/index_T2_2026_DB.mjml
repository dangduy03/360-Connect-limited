    <mj-section background-color="#FFFFFF" padding="20px 15px">
        <mj-column>

            <mj-section background-color= "#AB0618" padding="15px 0 15px 0" border-radius="4px">
                <mj-column>
                    <mj-text font-family="Montserrat, Arial, sans-serif" font-size="17px" color="#ffffff" font-weight="bold" align="center" padding="0">
                        TIN VUI: ĐỖ HOÀNG MINH ĐÃ ĐỖ VISA
                    </mj-text>
                </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="justify" padding="15px 0 2px 0" line-height="1.5">
                Nguyện vọng được học
                <span style="color: #AB0618; font-weight: bold;">Thạc sĩ</span> sau khi 
                <span style="color: #AB0618; font-weight: bold;">tốt nghiệp NEU, Đỗ Hoàng Minh </span>không ngừng nỗ lực hoàn thiện hồ sơ của mình. Đồng hành trên hành trình đó, 
                <span style="color: #AB0618; font-weight: bold;">360 Connect </span>đã hỗ trợ hết mình và chỉ sau 
                <span style="color: #AB0618; font-weight: bold;">5 tuần</span>, visa đã apply thành công cùng học bổng lên tới
                <span style="color: #AB0618; font-weight: bold;">10,000 AUD/năm </span> của
                <span style="color: #AB0618; font-weight: bold;"> Macquarie University.</span>Câu chuyện của 
                <span style="color: #AB0618; font-weight: bold;">Hoàng Minh</span> đã
                <span style="color: #AB0618; font-weight: bold;">“mở bát”</span>cho năm 
                <span style="color: #AB0618; font-weight: bold;">Bính Ngọ 2026</span>  rực rỡ của chúng mình! 

            </mj-text>

            

            <mj-section background-color="#fff" padding="25px 0 15px 0">
                <mj-column width="50%" >
                    <mj-image
                    href="https://360connect.edu.vn/bam-bao-ngoc-hoang-do-hoang-minh-da-do-visa/" 
