    <mj-section background-color="#FFFFFF" padding="20px 15px">
        <mj-column>

            <mj-section background-color= "#AB0618" padding="15px 0 15px 0" border-radius="4px">
                <mj-column>
                    <mj-text font-family="Montserrat, Arial, sans-serif" font-size="17px" color="#ffffff" font-weight="bold" align="center" padding="0">
                        TIN VUI: ÚC CHO PHÉP XIN VISA DU LỊCH THỜI HẠN 10 NĂM
                    </mj-text>
                </mj-column>
            </mj-section>

            <mj-text font-family="Montserrat, Arial, sans-serif" font-size="15px" font-style="italic" color="#2e2b2c" align="justify" padding="15px 0 2px 0" line-height="1.5">
                <span style="color: #AB0618; font-weight: bold;">Chính phủ Úc</span> đã mở diện 
                <span style="color: #AB0618; font-weight: bold;">Visa Du lịch 600 </span>cho phép công dân 
                <span style="color: #AB0618; font-weight: bold;">Việt Nam </span>có thể sở hữu visa lên đến 
                <span style="color: #AB0618; font-weight: bold;">10 năm</span>, thuận tiện cho những ai nhập cảnh nhiều lần để
                <span style="color: #AB0618; font-weight: bold;">du lịch, thăm thân</span> hay
                <span style="color: #AB0618; font-weight: bold;">công tác ngắn hạn</span>. Tuy nhiên để có được loại visa này, bạn cũng cần phải chuẩn bị
                <span style="color: #AB0618; font-weight: bold;">hồ sơ kỹ càng</span>, đáp ứng yêu cầu 
                <span style="color: #AB0618; font-weight: bold;">khắt khe</span>. Cùng
                <span style="color: #AB0618; font-weight: bold;">ML Migration</span> tìm hiểu ngay những thông tin mới nhất về
                <span style="color: #AB0618; font-weight: bold;">Visa Du lịch 600! </span> 

            </mj-text>

            

            <mj-section background-color="#fff" padding="25px 0 15px 0">
